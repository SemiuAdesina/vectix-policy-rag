# Copy to .env and fill in real values. Do not commit .env.

# Required for real embeddings and LLM (build_store, Streamlit, API, evaluation).
# Get a key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional. Directory for ChromaDB vector store persistence.
# Default: chroma_data (created in project root if missing)
CHROMA_PERSIST_DIR=chroma_data
